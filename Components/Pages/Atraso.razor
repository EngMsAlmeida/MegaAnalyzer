@page "/atraso"
@rendermode InteractiveServer
@using MegaAnalyzer.Models
@using MegaAnalyzer.Services
@using MegaAnalyzer.Services.Analysis
@inject ScrapingService Scraping

<h2>⏳ Atraso dos Números</h2>

<div class="mb-3">
    <label>Últimos quantos sorteios?</label>
    <input type="number" @bind="quantidade" min="10" max="200" class="form-control w-auto d-inline-block mx-2" />
    <button class="btn btn-primary" @onclick="Analisar" disabled="@carregando">
        @(carregando ? "Analisando..." : "🔍 Analisar")
    </button>
</div>

@if (!string.IsNullOrEmpty(erro))
{
    <div class="alert alert-danger">@erro</div>
}

@if (analisado)
{
    <!-- Mapa de atraso -->
    <h5>Mapa de Atraso (@quantidade sorteios)</h5>
    <div style="font-family:monospace;line-height:2.2">
        @foreach (var r in resultados.OrderBy(r => r.Numero))
        {
            var cor = r.Status switch {
                "Saiu agora"     => "background:#14532d;color:#86efac",
                "Recente"        => "background:#1a472a;color:#bbf7d0",
                "Normal"         => "background:#1f2937;color:#d1d5db",
                "Atrasado"       => "background:#78350f;color:#fde68a",
                _                => "background:#7f1d1d;color:#fca5a5"
            };
            <span style="display:inline-block;width:38px;text-align:center;margin:2px;padding:3px;border-radius:6px;font-size:0.8rem;@cor"
                  title="Atraso: @r.Atraso sorteios">
                @r.Numero.ToString("D2")
            </span>
            if (r.Numero % 10 == 0) { <br /> }
        }
    </div>
    <div class="mt-2 small d-flex gap-2 flex-wrap">
        <span style="background:#14532d;color:#86efac;padding:2px 8px;border-radius:4px">Saiu agora</span>
        <span style="background:#1a472a;color:#bbf7d0;padding:2px 8px;border-radius:4px">Recente (≤5)</span>
        <span style="background:#1f2937;color:#d1d5db;padding:2px 8px;border-radius:4px">Normal (≤10)</span>
        <span style="background:#78350f;color:#fde68a;padding:2px 8px;border-radius:4px">Atrasado (≤20)</span>
        <span style="background:#7f1d1d;color:#fca5a5;padding:2px 8px;border-radius:4px">Muito atrasado (&gt;20)</span>
    </div>

    <div class="row mt-4 g-4">
        <!-- Mais atrasados -->
        <div class="col-md-6">
            <h5>⏰ Mais Atrasados</h5>
            <table class="table table-dark table-sm">
                <thead>
                    <tr><th>Nº</th><th>Atraso</th><th>Último concurso</th><th>Status</th></tr>
                </thead>
                <tbody>
                    @foreach (var r in resultados.Take(20))
                    {
                        <tr>
                            <td><span class="badge bg-warning text-dark">@r.Numero.ToString("D2")</span></td>
                            <td>@r.Atraso sorteios</td>
                            <td>@(r.UltimoConcurso > 0 ? $"#{r.UltimoConcurso}" : "Não apareceu")</td>
                            <td>
                                @{
                                    var badgeClass = r.Status switch {
                                        "Muito atrasado" => "bg-danger",
                                        "Atrasado" => "bg-warning text-dark",
                                        _ => "bg-secondary"
                                    };
                                }
                                <span class="badge @badgeClass">@r.Status</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Mais recentes -->
        <div class="col-md-6">
            <h5>✅ Saíram Recentemente</h5>
            <table class="table table-dark table-sm">
                <thead>
                    <tr><th>Nº</th><th>Atraso</th><th>Último concurso</th><th>Status</th></tr>
                </thead>
                <tbody>
                    @foreach (var r in resultados.OrderBy(r => r.Atraso).Take(20))
                    {
                        <tr>
                            <td><span class="badge bg-success">@r.Numero.ToString("D2")</span></td>
                            <td>@r.Atraso sorteios</td>
                            <td>@(r.UltimoConcurso > 0 ? $"#{r.UltimoConcurso}" : "Não apareceu")</td>
                            <td>
                                @{
                                    var badgeClass2 = r.Status switch {
                                        "Saiu agora" => "bg-success",
                                        "Recente" => "bg-info text-dark",
                                        _ => "bg-secondary"
                                    };
                                }
                                <span class="badge @badgeClass2">@r.Status</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private int quantidade = 50;
    private bool carregando = false;
    private bool analisado = false;
    private string erro = string.Empty;
    private List<ResultadoAtraso> resultados = new();
    private AnaliseAtraso analise = new();

    private async Task Analisar()
    {
        carregando = true;
        erro = string.Empty;
        try
        {
            var sorteios = await Scraping.BuscarEAtualizarSorteiosAsync(quantidade);
            resultados = analise.Analisar(sorteios);
            analisado = true;
        }
        catch (Exception ex)
        {
            erro = ex.Message;
        }
        finally
        {
            carregando = false;
        }
    }
}