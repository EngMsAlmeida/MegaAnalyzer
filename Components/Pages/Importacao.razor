@page "/importacao"
@rendermode InteractiveServer
@using MegaAnalyzer.Services
@inject ImportacaoService ImportacaoSvc

<h2>📥 Importação de Histórico</h2>

<div class="p-3 rounded mb-4" style="background:#111827;border:1px solid #374151">
    <h5>Importar via API Oficial da Caixa</h5>
    <p class="text-muted small">Importa o histórico completo diretamente da API da Caixa Econômica Federal.</p>

    <div class="d-flex gap-3 align-items-center flex-wrap mb-3">
        <div>
            <label class="small">Concurso início</label>
            <input type="number" @bind="inicio" min="1" max="3003" class="form-control" style="width:120px" />
        </div>
        <div>
            <label class="small">Concurso fim</label>
            <input type="number" @bind="fim" min="1" max="3003" class="form-control" style="width:120px" />
        </div>
        <div class="mt-3">
            <button class="btn btn-primary" @onclick="Importar" disabled="@importando">
                @(importando ? "Importando..." : "📥 Importar")
            </button>
            <button class="btn btn-secondary ms-2" @onclick="DetectarUltimo" disabled="@importando">
                🔍 Detectar último concurso
            </button>
        </div>
    </div>

    @if (importando)
    {
        <div class="alert alert-info">
            ⏳ Importando concurso @concursoAtual de @inicio a @fim...
            <div class="progress mt-2" style="height:20px">
                <div class="progress-bar progress-bar-striped progress-bar-animated"
                     style="width:@porcentagem%">@porcentagem%</div>
            </div>
        </div>
    }

    @if (!string.IsNullOrEmpty(resultado))
    {
        <div class="alert @(erro ? "alert-danger" : "alert-success") mt-3">
            @resultado
        </div>
    }
</div>

<div class="p-3 rounded" style="background:#111827;border:1px solid #374151">
    <h5>💡 Dica de uso</h5>
    <p class="text-muted small mb-1">A Mega-Sena existe desde 1996 e já tem mais de 3000 concursos.</p>
    <p class="text-muted small mb-1">Importar tudo de uma vez pode demorar alguns minutos por causa da pausa entre requisições.</p>
    <p class="text-muted small">Sugestão: importe em blocos de 500 concursos por vez.</p>

    <div class="d-flex gap-2 flex-wrap mt-3">
        <button class="btn btn-outline-secondary btn-sm" @onclick="() => SetRange(1, 500)">Bloco 1 (1-500)</button>
        <button class="btn btn-outline-secondary btn-sm" @onclick="() => SetRange(501, 1000)">Bloco 2 (501-1000)</button>
        <button class="btn btn-outline-secondary btn-sm" @onclick="() => SetRange(1001, 1500)">Bloco 3 (1001-1500)</button>
        <button class="btn btn-outline-secondary btn-sm" @onclick="() => SetRange(1501, 2000)">Bloco 4 (1501-2000)</button>
        <button class="btn btn-outline-secondary btn-sm" @onclick="() => SetRange(2001, 2500)">Bloco 5 (2001-2500)</button>
        <button class="btn btn-outline-secondary btn-sm" @onclick="() => SetRange(2501, 3003)">Bloco 6 (2501-3003)</button>
    </div>
</div>

@code {
    private int inicio = 1;
    private int fim = 100;
    private bool importando = false;
    private bool erro = false;
    private string resultado = string.Empty;
    private int concursoAtual = 0;
    private double porcentagem = 0;

    private async Task DetectarUltimo()
    {
        fim = await ImportacaoSvc.ObterUltimoConcursoAsync();
    }

    private void SetRange(int i, int f)
    {
        inicio = i;
        fim = f;
    }

    private async Task Importar()
    {
        importando = true;
        resultado = string.Empty;
        erro = false;
        concursoAtual = inicio;

        try
        {
            var total = fim - inicio + 1;
            var progresso = new Progress<int>(c =>
            {
                concursoAtual = c;
                porcentagem = Math.Round((double)(c - inicio + 1) / total * 100, 1);
                InvokeAsync(StateHasChanged);
            });

            var (importados, ignorados) = await ImportacaoSvc.ImportarHistoricoAsync(inicio, fim, progresso);
            resultado = $"✅ Concluído! {importados} importados, {ignorados} já existiam ou com erro.";
        }
        catch (Exception ex)
        {
            erro = true;
            resultado = $"Erro: {ex.Message}";
        }
        finally
        {
            importando = false;
            porcentagem = 100;
        }
    }
}